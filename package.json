{
  "name": "brushspace",
  "version": "0.1.0",
  "description": "A WebXR 3D painting app partially ported from Open Brush and adapted for the web, built with the Immersive Web SDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/felixtrz/brushspace.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "assets:brushes": "node scripts/sync-icosa-brush-assets.mjs",
    "predev": "npm run assets:brushes",
    "dev": "iwsdk dev up --open --foreground",
    "dev:runtime": "vite",
    "dev:down": "iwsdk dev down",
    "dev:status": "iwsdk dev status",
    "reference:status": "iwsdk reference status",
    "reference:warmup": "iwsdk reference warmup",
    "typecheck": "tsc --noEmit",
    "check:imports": "node scripts/check-imports.mjs",
    "extract:brush-assets": "node scripts/extract-brush-assets.mjs",
    "check:features": "node scripts/check-feature-flags.mjs",
    "check": "npm run typecheck && npm run check:imports && npm run check:features && npm run test:brush-images && npm test",
    "test": "vitest run",
    "test:brush-images": "node --test scripts/compare-brush-images.node-test.mjs",
    "test:browser": "node scripts/runtime-check.mjs browser",
    "test:xr": "node scripts/runtime-check.mjs xr",
    "prebuild": "npm run assets:brushes",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iwsdk/core": "0.4.2",
    "@iwsdk/xr-input": "0.4.2",
    "@pmndrs/uikit-horizon": "^1.0.74",
    "@pmndrs/uikit-lucide": "^1.0.74",
    "peerjs": "^1.5.5",
    "three": "npm:super-three@0.181.0",
    "three-icosa": "https://github.com/icosa-foundation/three-icosa/archive/67b30b4ae7cee4329c7ecc3289c4edc9c77dc3fd.tar.gz",
    "three-tiltloader": "https://github.com/icosa-foundation/three-tiltloader/archive/164454729442345fa19144471cf762b56fbc4518.tar.gz"
  },
  "devDependencies": {
    "@iwsdk/cli": "0.4.2",
    "@iwsdk/reference": "0.4.2",
    "@iwsdk/vite-plugin-dev": "0.4.2",
    "@iwsdk/vite-plugin-uikitml": "0.4.2",
    "@meta-quest/hzdb": "^1.0.0",
    "@types/three": "*",
    "sharp": "^0.34.5",
    "typescript": "^5.5.0",
    "vite": "^7.1.4",
    "vite-plugin-mkcert": "^1.17.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19.0 <21.0.0-0 || >=22.12.0 <23.0.0-0 || >=24.0.0"
  }
}
